---
const products = [
	{
		name: 'Pan Integral',
		description: 'Corteza crujiente, miga húmeda y notas a tostado.',
		image:
			'https://images.unsplash.com/photo-1549931319-a545dcf3bc73?auto=format&fit=crop&w=1400&q=80',
		tag: null,
	},
	{
		name: 'Mermelada Artesanal',
		description: 'Fruta real, cocción lenta y acidez perfecta.',
		image:
			'https://images.unsplash.com/photo-1664810029952-88b5f9548d11?auto=format&fit=crop&w=1400&q=80',
		tag: null,
	},
	{
		name: 'Pan de Pascua',
		description: 'Especias, frutos secos y un aroma que abraza.',
		image:
			'https://images.unsplash.com/photo-1628471036342-adf99e82f1ac?auto=format&fit=crop&w=1400&q=80',
		tag: 'Favorito de la temporada',
	},
] as const;
---
<section id="delicias" class="section">
	<div class="container-page">
		<div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
			<div class="max-w-2xl">
				<h2 class="font-serif text-3xl font-bold tracking-tight text-tostado" data-aos="fade-up">
					Nuestras delicias
				</h2>
				<p class="mt-3 text-cacao/70" data-aos="fade-up" data-aos-delay="80">
					Una selección pequeña, cuidada y siempre fresca.
				</p>
			</div>
			<a href="#contacto" class="btn-secondary w-full md:w-auto" data-aos="fade-up" data-aos-delay="120">
				Quiero pedir por WhatsApp
			</a>
		</div>

		<div class="mt-10 grid gap-6 md:grid-cols-3">
			{products.map((p, idx) => (
				<article
					class:list={[
						'group overflow-hidden rounded-2xl border border-white/60 bg-white/70 shadow-soft backdrop-blur transition hover:-translate-y-0.5 hover:shadow-glow',
						p.tag ? 'ring-1 ring-mermelada/20' : '',
					]}
					data-aos="fade-up"
					data-aos-delay={String(120 + idx * 100)}
				>
					<div class="relative h-56 overflow-hidden">
						<img
							src={p.image}
							alt={p.name}
							loading="lazy"
							decoding="async"
							class="h-full w-full object-cover transition duration-500 ease-out group-hover:scale-110"
						/>
						<div class="absolute inset-0 bg-gradient-to-t from-cacao/35 via-transparent to-transparent" />

						{p.tag && (
							<div class="absolute left-4 top-4">
								<span class="inline-flex items-center rounded-full bg-mermelada px-3 py-1 text-xs font-bold text-white shadow">
									{p.tag}
								</span>
							</div>
						)}
					</div>

					<div class="p-6">
						<h3 class="text-lg font-bold text-cacao">{p.name}</h3>
						<p class="mt-2 text-sm leading-relaxed text-cacao/70">{p.description}</p>

						<div class="mt-5 flex items-center justify-between">
							<span class="text-xs font-semibold text-cacao/50">Disponible por encargo</span>
							<a href="#contacto" class="text-sm font-bold text-tostado hover:text-cacao">
								Pedir →
							</a>
						</div>
					</div>
				</article>
			))}
		</div>
	</div>
</section>

