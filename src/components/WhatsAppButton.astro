---
type Props = {
	phone: string;
	message?: string;
};

const { phone, message = 'Hola! Quiero hacer un pedido en Dulce-mente.' } = Astro.props as Props;
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
	href={href}
	target="_blank"
	rel="noopener noreferrer"
	aria-label="Pedir por WhatsApp"
	class="fixed bottom-5 right-5 z-50 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-[#25D366] text-white shadow-glow ring-1 ring-white/40 transition hover:scale-105 focus:outline-none focus:ring-4 focus:ring-mermelada/30 animate-pulseSoft"
>
	<svg
		aria-hidden="true"
		viewBox="0 0 32 32"
		class="h-7 w-7 fill-current"
	>
