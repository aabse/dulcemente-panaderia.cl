		<div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
			<div>
				<p class="font-serif text-xl font-semibold text-tostado">Dulce-mente</p>
				<p class="mt-1 text-sm text-cacao/70">Panadería artesanal · Hecho con cariño.</p>
			</div>

			<nav class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
				<a class="text-cacao/70 hover:text-cacao" href="#delicias">Delicias</a>
				<a class="text-cacao/70 hover:text-cacao" href="#historia">Historia</a>
				<a class="text-cacao/70 hover:text-cacao" href="#contacto">Contacto</a>
