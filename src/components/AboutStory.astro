---
const blocks = [
	{
		title: 'Manos, tiempo y masa madre',
		body: 'Amasamos, plegamos y dejamos que la fermentación haga su magia. Sin apuros: cada etapa construye sabor, textura y aroma.',
		image:
			'https://images.unsplash.com/photo-1619710282877-638d7ee1e45d?auto=format&fit=crop&w=1600&q=80',
	},
	{
		title: 'Horno caliente, corazón tranquilo',
		body: 'Horneamos en tandas pequeñas para cuidar el punto exacto: dorado tostado, corteza firme y miga suave.',
		image:
			'https://images.unsplash.com/photo-1593285702005-ccc93dfe7cfb??auto=format&fit=crop&w=1600&q=80',
	},
] as const;
---

<section id="historia" class="section">
	<div class="container-page">
		<div class="max-w-2xl">
			<h2 class="font-serif text-3xl font-bold tracking-tight text-tostado" data-aos="fade-up">
				Nuestra historia
			</h2>
			<p class="mt-3 text-cacao/70" data-aos="fade-up" data-aos-delay="80">
				Lo artesanal no es una etiqueta: es una forma de trabajar.
			</p>
		</div>

		<div class="mt-12 space-y-10">
			{blocks.map((b, idx) => (
				<div
					class:list={[
						'grid items-center gap-8 rounded-2xl border border-white/60 bg-white/60 p-6 shadow-soft backdrop-blur md:grid-cols-2 md:p-10',
						idx % 2 === 1 ? 'md:[&>div:first-child]:order-2' : '',
					]}
					data-aos="fade-up"
					data-aos-delay={String(120 + idx * 100)}
				>
					<div>
						<h3 class="font-serif text-2xl font-bold text-cacao">{b.title}</h3>
						<p class="mt-3 leading-relaxed text-cacao/70">{b.body}</p>
						<ul class="mt-5 grid gap-2 text-sm text-cacao/70">
							<li class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-mermelada/70" />
								Fermentación lenta
							</li>
							<li class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-mermelada/70" />
								Ingredientes reales
							</li>
							<li class="flex items-center gap-2">
								<span class="h-1.5 w-1.5 rounded-full bg-mermelada/70" />
								Tandas pequeñas
							</li>
						</ul>
					</div>

					<div class="overflow-hidden rounded-2xl ring-1 ring-white/60">
						<img
							src={b.image}
							alt={b.title}
							loading="lazy"
							decoding="async"
							class="h-[280px] w-full object-cover transition duration-700 ease-out hover:scale-105 md:h-[340px]"
						/>
					</div>
				</div>
			))}
		</div>
	</div>
</section>

