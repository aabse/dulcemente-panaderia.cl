---
const nav = [
	{ href: '#delicias', label: 'Delicias' },
	{ href: '#historia', label: 'Nuestra historia' },
	{ href: '#contacto', label: 'Contacto' },
];
---

<header class="sticky top-0 z-40 border-b border-white/50 bg-white/40 backdrop-blur supports-[backdrop-filter]:bg-white/30">
	<div class="container-page">
		<div class="flex h-16 items-center justify-between gap-4">
			<a href="#" class="group inline-flex items-baseline gap-2">
				<span class="font-serif text-xl font-bold tracking-tight text-tostado">Dulce-mente</span>
				<span class="hidden text-xs font-semibold text-mermelada/80 sm:inline">artesanal</span>
			</a>

			<nav class="hidden items-center gap-7 md:flex">
				{nav.map((item) => (
					<a
						href={item.href}
						class="text-sm font-semibold text-cacao/70 transition hover:text-cacao"
					>
						{item.label}
					</a>
				))}
				<a href="#contacto" class="btn-primary">
					Pedir por WhatsApp
				</a>
			</nav>

			<details class="group relative md:hidden">
				<summary class="list-none rounded-xl px-3 py-2 text-sm font-semibold text-cacao/80 ring-1 ring-white/70 hover:bg-white/60">
					Menú
				</summary>
				<div
					class="absolute right-0 mt-2 w-64 overflow-hidden rounded-2xl border border-white/60 bg-white/80 p-2 shadow-soft backdrop-blur"
				>
					<div class="flex flex-col">
						{nav.map((item) => (
							<a
								href={item.href}
								class="rounded-xl px-3 py-2 text-sm font-semibold text-cacao/70 hover:bg-white"
							>
								{item.label}
							</a>
						))}
						<a href="#contacto" class="mt-2 btn-primary w-full">
							Pedir por WhatsApp
						</a>
					</div>
				</div>
			</details>
		</div>
	</div>
</header>

